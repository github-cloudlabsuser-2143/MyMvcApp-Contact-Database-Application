{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "appServiceName": {
            "value": "myMvcAppService"
        },
        "appServicePlanName": {
            "value": "myMvcAppServicePlan"
        },
        "skuName": {
            "value": "S1"
        },
        "skuCapacity": {
            "value": 1
        },
        "location": {
            "value": "West US"
        },
        "databaseName": {
            "value": "myMvcAppDatabase"
        },
        "databaseServerName": {
            "value": "myMvcAppDbServer"
        },
        "databaseUsername": {
            "value": "dbAdmin"
        },
        "databasePassword": {
            "value": "yourStrongPassword"
        }
    }
}